# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.Python
build/
dist/

# ---------------------------------------------------------------------------
# OS / editor
# ---------------------------------------------------------------------------
.DS_Store
._*
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
